{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "outDir": "./static/js",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "node_modules",
    "**/*.js"  // 🎯 모든 .js 파일을 컴파일 대상에서 제외하여 충돌을 방지합니다.
  ]
}